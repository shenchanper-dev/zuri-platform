import { z } from 'zod';

// DNI: 8 dígitos
const dniSchema = z.string()
  .length(8, 'DNI debe tener 8 dígitos')
  .regex(/^\d{8}$/, 'DNI solo números');

// Celular: 9 dígitos, empieza con 9
const celularSchema = z.string()
  .length(9, 'Celular debe tener 9 dígitos')
  .regex(/^9\d{8}$/, 'Celular debe empezar con 9');

// Email válido
const emailSchema = z.string()
  .email('Email no válido')
  .min(1, 'Email requerido');

// Edad entre 18 y 70
const fechaNacimientoSchema = z.string()
  .refine((date) => {
    const birthDate = new Date(date);
    const today = new Date();
    const age = today.getFullYear() - birthDate.getFullYear();
    return age >= 18 && age <= 70;
  }, 'Edad debe ser entre 18 y 70 años');

export const conductorSchema = z.object({
  // OBLIGATORIOS
  dni: dniSchema,
  nombreCompleto: z.string().min(1).max(200),
  fechaNacimiento: fechaNacimientoSchema,
  celular1: celularSchema,

  // OPCIONALES
  nombres: z.string().max(100).optional(),
  apellidos: z.string().max(100).optional(),
  celular2: celularSchema.optional().or(z.literal('')),
  domicilio: z.string().max(255).optional(),
  email: emailSchema.optional(),
  numeroBrevete: z.string().min(1).max(12),
  fechaVencimientoBrevete: z.string().optional(),
  marcaAuto: z.string().max(50).optional(),
  modelo: z.string().max(50).optional(),
  numeroPlaca: z.string().max(10).optional(),
  propietario: z.string().max(200).optional(),
  estadoCivil: z.enum(['SOLTERO', 'CASADO', 'DIVORCIADO', 'VIUDO', 'CONVIVIENTE']).optional(),
  numeroHijos: z.number().int().min(0).max(20).optional(),
  nombreContacto: z.string().max(200).optional(),
  celularContacto: celularSchema.optional().or(z.literal('')),
  estado: z.enum(['ACTIVO', 'INACTIVO', 'EN_PERMISO', 'RETIRADO']).default('ACTIVO'),
  fechaIngreso: z.string().optional(),
  fechaCese: z.string().optional(),
  observaciones: z.string().max(1000).optional(),
  id: z.number().optional(),
  createdAt: z.string().optional(),
  updatedAt: z.string().optional(),
});

export const conductorUpdateSchema = conductorSchema.partial().required({ id: true });

export type Conductor = z.infer<typeof conductorSchema>;
export type ConductorUpdate = z.infer<typeof conductorUpdateSchema>;

export function validateConductorCreate(data: unknown) {
  return conductorSchema.safeParse(data);
}

export function validateConductorUpdate(data: unknown) {
  return conductorUpdateSchema.safeParse(data);
}

export const MARCAS_AUTO = [
  'Toyota', 'Kia', 'Hyundai', 'Nissan', 'Chevrolet', 'Suzuki', 'Volkswagen',
  'Mitsubishi', 'Ford', 'Renault', 'BMW', 'Mercedes Benz', 'Audi', 'Jeep',
  'Land Rover', 'Volvo', 'BAIC', 'Brilliance', 'BYD', 'Changan', 'Chery',
  'DFSK', 'Dongfeng', 'FAW', 'Foton', 'Geely', 'Great Wall', 'Haval',
  'JAC', 'Jinbei', 'Joylong', 'Kenbo', 'Otro'
] as const;
