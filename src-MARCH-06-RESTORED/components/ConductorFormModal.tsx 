// ============================================================================
// COMPONENTE: ConductorFormModal
// DESCRIPCIÓN: Modal con formulario completo para crear/editar conductores
// INCLUYE: 24 campos + validaciones + geocodificación
// ============================================================================

'use client';

import { useState, useEffect } from 'react';
import { ConductorData } from '@/hooks/useConductores';

interface ConductorFormModalProps {
  isOpen: boolean;
  onClose: () => void;
  onSave: (data: Partial<ConductorData>) => Promise<{ success: boolean; error?: string }>;
  conductor: ConductorData | null;
  saving: boolean;
}

const MARCAS_VEHICULOS = [
  'Toyota', 'Kia', 'Hyundai', 'Nissan', 'Chevrolet', 'Suzuki',
  'Volkswagen', 'Mitsubishi', 'Ford', 'Renault', 'Mazda', 'Honda',
  'BYD', 'Changan', 'Chery', 'JAC', 'Great Wall', 'Otro',
];

const TIPOS_VEHICULO = [
  { value: 'SEDAN', label: 'Sedán' },
  { value: 'SUV', label: 'SUV' },
  { value: 'VAN', label: 'Van' },
  { value: 'WHEELCHAIR_ACCESSIBLE', label: 'Accesible para silla de ruedas' },
  { value: 'STRETCHER', label: 'Transporte de camilla' },
  { value: 'AMBULANCE', label: 'Ambulancia' },
];

const ESTADOS_CIVIL = ['SOLTERO', 'CASADO', 'DIVORCIADO', 'VIUDO'];

const DISTRITOS_LIMA = [
  'Ancón', 'Ate', 'Barranco', 'Breña', 'Carabayllo', 'Chaclacayo',
  'Chorrillos', 'Cieneguilla', 'Comas', 'El Agustino', 'Independencia',
  'Jesús María', 'La Molina', 'La Victoria', 'Lima', 'Lince',
  'Los Olivos', 'Lurigancho', 'Lurín', 'Magdalena del Mar', 'Miraflores',
  'Pachacámac', 'Pucusana', 'Pueblo Libre', 'Puente Piedra', 'Punta Hermosa',
  'Punta Negra', 'Rímac', 'San Bartolo', 'San Borja', 'San Isidro',
  'San Juan de Lurigancho', 'San Juan de Miraflores', 'San Luis',
  'San Martín de Porres', 'San Miguel', 'Santa Anita', 'Santa María del Mar',
  'Santa Rosa', 'Santiago de Surco', 'Surquillo', 'Villa El Salvador',
  'Villa María del Triunfo',
];

export default function ConductorFormModal({
  isOpen,
  onClose,
  onSave,
  conductor,
  saving,
}: ConductorFormModalProps) {
  const [formData, setFormData] = useState<Partial<ConductorData>>({});
  const [errors, setErrors] = useState<Record<string, string>>({});
  const [seccionActual, setSeccionActual] = useState<number>(1);
  const [buscandoGPS, setBuscandoGPS] = useState(false);

  // Inicializar formulario
  useEffect(() => {
    if (conductor) {
      setFormData(conductor);
    } else {
      setFormData({
        estado: 'ACTIVO',
        capacidadPasajeros: 4,
        tipoVehiculo: 'SEDAN',
        numeroHijos: 0,
        fechaIngreso: new Date().toISOString().split('T')[0],
      });
    }
  }, [conductor]);

  if (!isOpen) return null;

  // =========================================================================
  // VALIDACIONES
  // =========================================================================

  const validarCampo = (campo: string, valor: any): string | null => {
    switch (campo) {
      case 'dni':
        if (!valor || !/^[0-9]{8}$/.test(valor)) {
          return 'DNI debe tener 8 dígitos';
        }
        break;

      case 'nombreCompleto':
        if (!valor || valor.trim().length < 3) {
          return 'Nombre completo es requerido (mínimo 3 caracteres)';
        }
        break;

      case 'fechaNacimiento':
        if (!valor) return 'Fecha de nacimiento es requerida';
        const edad = calcularEdad(valor);
        if (edad < 18) return 'Debe ser mayor de 18 años';
        if (edad > 70) return 'No puede ser mayor de 70 años';
        break;

      case 'celular1':
        if (!valor || !/^9[0-9]{8}$/.test(valor)) {
          return 'Celular debe tener 9 dígitos y empezar con 9';
        }
        break;

      case 'celular2':
        if (valor && !/^9[0-9]{8}$/.test(valor)) {
          return 'Celular debe tener 9 dígitos y empezar con 9';
        }
        break;

      case 'email':
        if (!valor || !/^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$/.test(valor)) {
          return 'Email inválido';
        }
        break;

      case 'domicilioCompleto':
        if (!valor || valor.trim().length < 10) {
          return 'Domicilio completo es requerido (mínimo 10 caracteres)';
        }
        break;

      case 'numeroBrevete':
        if (!valor || valor.trim().length < 5) {
          return 'Número de brevete es requerido';
        }
        break;

      case 'marcaVehiculo':
        if (!valor || valor.trim().length < 2) {
          return 'Marca de vehículo es requerida';
        }
        break;

      case 'modeloVehiculo':
        if (!valor || valor.trim().length < 2) {
          return 'Modelo de vehículo es requerido';
        }
        break;

      case 'placa':
        if (valor && !/^[A-Z0-9]{6,7}$/.test(valor.toUpperCase())) {
          return 'Placa inválida (6-7 caracteres alfanuméricos)';
        }
        break;
    }

    return null;
  };

  const calcularEdad = (fechaNacimiento: string): number => {
    const hoy = new Date();
    const nacimiento = new Date(fechaNacimiento);
    let edad = hoy.getFullYear() - nacimiento.getFullYear();
    const mes = hoy.getMonth() - nacimiento.getMonth();
    if (mes < 0 || (mes === 0 && hoy.getDate() < nacimiento.getDate())) {
      edad--;
    }
    return edad;
  };

  const handleChange = (campo: string, valor: any) => {
    setFormData(prev => ({ ...prev, [campo]: valor }));
    
    // Validar en tiempo real
    const error = validarCampo(campo, valor);
    setErrors(prev => {
      if (error) {
        return { ...prev, [campo]: error };
      } else {
        const { [campo]: _, ...rest } = prev;
        return rest;
      }
    });
  };

  // =========================================================================
  // GEOCODIFICACIÓN DE DOMICILIO
  // =========================================================================

  const buscarCoordenadasDomicilio = async () => {
    if (!formData.domicilioCompleto || !formData.domicilioDistrito) {
      alert('Por favor complete el domicilio y distrito primero');
      return;
    }

    setBuscandoGPS(true);

    try {
      // Usar Nominatim de OpenStreetMap para geocodificación
      const direccionCompleta = `${formData.domicilioCompleto}, ${formData.domicilioDistrito}, Lima, Perú`;
      const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(direccionCompleta)}&limit=1`;

      const response = await fetch(url);
      const data = await response.json();

      if (data && data.length > 0) {
        const { lat, lon } = data[0];
        setFormData(prev => ({
          ...prev,
          domicilioLatitud: parseFloat(lat),
          domicilioLongitud: parseFloat(lon),
        }));
        alert('✅ Coordenadas encontradas exitosamente');
      } else {
        alert('⚠️ No se encontraron coordenadas. Ingrese manualmente.');
      }
    } catch (error) {
      console.error('Error al buscar coordenadas:', error);
      alert('❌ Error al buscar coordenadas. Intente manualmente.');
    } finally {
      setBuscandoGPS(false);
    }
  };

  // =========================================================================
  // SUBMIT
  // =========================================================================

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();

    // Validar todos los campos obligatorios
    const camposObligatorios = [
      'dni',
      'nombreCompleto',
      'fechaNacimiento',
      'celular1',
      'email',
      'domicilioCompleto',
      'numeroBrevete',
      'marcaVehiculo',
      'modeloVehiculo',
    ];

    const nuevosErrores: Record<string, string> = {};

    camposObligatorios.forEach(campo => {
      const error = validarCampo(campo, formData[campo as keyof ConductorData]);
      if (error) {
        nuevosErrores[campo] = error;
      }
    });

    if (Object.keys(nuevosErrores).length > 0) {
      setErrors(nuevosErrores);
      alert('Por favor corrija los errores en el formulario');
      return;
    }

    const result = await onSave(formData);

    if (!result.success) {
      alert(`Error: ${result.error}`);
    }
  };

  // =========================================================================
  // RENDERIZADO
  // =========================================================================

  return (
    <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
      <div className="bg-white rounded-lg max-w-5xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">
        {/* HEADER */}
        <div className="sticky top-0 bg-gradient-to-r from-blue-600 to-blue-700 text-white px-6 py-4 flex items-center justify-between z-10">
          <div>
            <h2 className="text-2xl font-bold">
              {conductor ? 'Editar Conductor' : 'Nuevo Conductor NEMT'}
            </h2>
            <p className="text-blue-100 text-sm mt-1">
              Complete todos los campos obligatorios marcados con *
            </p>
          </div>
          <button
            onClick={onClose}
            className="text-white hover:bg-blue-800 rounded-full p-2 transition-colors"
            disabled={saving}
          >
            <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        {/* NAVEGACIÓN DE SECCIONES */}
        <div className="bg-gray-50 px-6 py-3 border-b">
          <div className="flex gap-2 overflow-x-auto">
            {[
              { num: 1, nombre: 'Personal' },
              { num: 2, nombre: 'Domicilio' },
              { num: 3, nombre: 'Contacto' },
              { num: 4, nombre: 'Vehículo' },
              { num: 5, nombre: 'Estado' },
            ].map(seccion => (
              <button
                key={seccion.num}
                onClick={() => setSeccionActual(seccion.num)}
                className={`px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap ${
                  seccionActual === seccion.num
                    ? 'bg-blue-600 text-white'
                    : 'bg-white text-gray-600 hover:bg-gray-100'
                }`}
              >
                {seccion.num}. {seccion.nombre}
              </button>
            ))}
          </div>
        </div>

        <form onSubmit={handleSubmit} className="p-6 space-y-6">
          {/* SECCIÓN 1: INFORMACIÓN PERSONAL */}
          {seccionActual === 1 && (
            <div className="space-y-4">
              <h3 className="text-lg font-semibold text-gray-900 border-b pb-2">
                📋 Información Personal
              </h3>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {/* DNI */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    DNI * <span className="text-xs text-gray-500">(8 dígitos)</span>
                  </label>
                  <input
                    type="text"
                    maxLength={8}
                    value={formData.dni || ''}
                    onChange={(e) => handleChange('dni', e.target.value.replace(/\D/g, ''))}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.dni ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    placeholder="12345678"
                    disabled={!!conductor} // DNI no editable
                  />
                  {errors.dni && <p className="text-red-500 text-xs mt-1">{errors.dni}</p>}
                </div>

                {/* Nombre Completo */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Nombre Completo *
                  </label>
                  <input
                    type="text"
                    value={formData.nombreCompleto || ''}
                    onChange={(e) => handleChange('nombreCompleto', e.target.value.toUpperCase())}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.nombreCompleto ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    placeholder="JUAN PÉREZ GARCÍA"
                  />
                  {errors.nombreCompleto && <p className="text-red-500 text-xs mt-1">{errors.nombreCompleto}</p>}
                </div>

                {/* Fecha de Nacimiento */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Fecha de Nacimiento * <span className="text-xs text-gray-500">(18-70 años)</span>
                  </label>
                  <input
                    type="date"
                    value={formData.fechaNacimiento || ''}
                    onChange={(e) => handleChange('fechaNacimiento', e.target.value)}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.fechaNacimiento ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    max={new Date(new Date().setFullYear(new Date().getFullYear() - 18)).toISOString().split('T')[0]}
                    min={new Date(new Date().setFullYear(new Date().getFullYear() - 70)).toISOString().split('T')[0]}
                  />
                  {errors.fechaNacimiento && <p className="text-red-500 text-xs mt-1">{errors.fechaNacimiento}</p>}
                  {formData.fechaNacimiento && (
                    <p className="text-sm text-gray-600 mt-1">
                      Edad: {calcularEdad(formData.fechaNacimiento)} años
                    </p>
                  )}
                </div>

                {/* Celular Principal */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Celular Principal * <span className="text-xs text-gray-500">(9 dígitos, inicia con 9)</span>
                  </label>
                  <input
                    type="tel"
                    maxLength={9}
                    value={formData.celular1 || ''}
                    onChange={(e) => handleChange('celular1', e.target.value.replace(/\D/g, ''))}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.celular1 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    placeholder="987654321"
                  />
                  {errors.celular1 && <p className="text-red-500 text-xs mt-1">{errors.celular1}</p>}
                </div>

                {/* Celular Secundario */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Celular Secundario <span className="text-xs text-gray-500">(opcional)</span>
                  </label>
                  <input
                    type="tel"
                    maxLength={9}
                    value={formData.celular2 || ''}
                    onChange={(e) => handleChange('celular2', e.target.value.replace(/\D/g, ''))}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.celular2 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    placeholder="912345678"
                  />
                  {errors.celular2 && <p className="text-red-500 text-xs mt-1">{errors.celular2}</p>}
                </div>

                {/* Email */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Email *
                  </label>
                  <input
                    type="email"
                    value={formData.email || ''}
                    onChange={(e) => handleChange('email', e.target.value.toLowerCase())}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.email ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    placeholder="conductor@zuri.pe"
                  />
                  {errors.email && <p className="text-red-500 text-xs mt-1">{errors.email}</p>}
                </div>

                {/* Estado Civil */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Estado Civil
                  </label>
                  <select
                    value={formData.estadoCivil || ''}
                    onChange={(e) => handleChange('estadoCivil', e.target.value)}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                  >
                    <option value="">Seleccione...</option>
                    {ESTADOS_CIVIL.map(estado => (
                      <option key={estado} value={estado}>{estado}</option>
                    ))}
                  </select>
                </div>

                {/* Número de Hijos */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Número de Hijos
                  </label>
                  <input
                    type="number"
                    min="0"
                    max="20"
                    value={formData.numeroHijos || 0}
                    onChange={(e) => handleChange('numeroHijos', parseInt(e.target.value) || 0)}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                  />
                </div>
              </div>
            </div>
          )}

          {/* SECCIÓN 2: DOMICILIO Y GPS */}
          {seccionActual === 2 && (
            <div className="space-y-4">
              <h3 className="text-lg font-semibold text-gray-900 border-b pb-2">
                🏠 Domicilio y Ubicación GPS
              </h3>

              {/* Domicilio Completo */}
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Domicilio Completo *
                </label>
                <textarea
                  rows={2}
                  value={formData.domicilioCompleto || ''}
                  onChange={(e) => handleChange('domicilioCompleto', e.target.value)}
                  className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                    errors.domicilioCompleto ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                  }`}
                  placeholder="Av. Arequipa 1234, San Isidro"
                />
                {errors.domicilioCompleto && <p className="text-red-500 text-xs mt-1">{errors.domicilioCompleto}</p>}
              </div>

              {/* Distrito */}
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Distrito
                </label>
                <select
                  value={formData.domicilioDistrito || ''}
                  onChange={(e) => handleChange('domicilioDistrito', e.target.value)}
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
                  <option value="">Seleccione distrito...</option>
                  {DISTRITOS_LIMA.map(distrito => (
                    <option key={distrito} value={distrito}>{distrito}</option>
                  ))}
                </select>
              </div>

              {/* Auto-detectar Coordenadas */}
              <div className="bg-blue-50 border border-blue-200 rounded-lg p-4">
                <p className="text-sm text-blue-800 mb-3">
                  📍 Las coordenadas GPS son necesarias para mostrar al conductor en el mapa
                </p>
                <button
                  type="button"
                  onClick={buscarCoordenadasDomicilio}
                  disabled={buscandoGPS || !formData.domicilioCompleto}
                  className="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium disabled:bg-gray-400"
                >
                  {buscandoGPS ? 'Buscando...' : '🔍 Auto-detectar Coordenadas GPS'}
                </button>
              </div>

              {/* Coordenadas GPS Manuales */}
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Latitud <span className="text-xs text-gray-500">(ej: -12.0941)</span>
                  </label>
                  <input
                    type="number"
                    step="0.000001"
                    value={formData.domicilioLatitud || ''}
                    onChange={(e) => handleChange('domicilioLatitud', parseFloat(e.target.value))}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="-12.0941"
                  />
                </div>

                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Longitud <span className="text-xs text-gray-500">(ej: -77.0365)</span>
                  </label>
                  <input
                    type="number"
                    step="0.000001"
                    value={formData.domicilioLongitud || ''}
                    onChange={(e) => handleChange('domicilioLongitud', parseFloat(e.target.value))}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="-77.0365"
                  />
                </div>
              </div>

              {formData.domicilioLatitud && formData.domicilioLongitud && (
                <div className="bg-green-50 border border-green-200 rounded-lg p-3">
                  <p className="text-sm text-green-800">
                    ✅ Coordenadas GPS configuradas: {formData.domicilioLatitud}, {formData.domicilioLongitud}
                  </p>
                </div>
              )}
            </div>
          )}

          {/* SECCIÓN 3: CONTACTO DE EMERGENCIA */}
          {seccionActual === 3 && (
            <div className="space-y-4">
              <h3 className="text-lg font-semibold text-gray-900 border-b pb-2">
                🚨 Contacto de Emergencia
              </h3>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Nombre del Contacto
                  </label>
                  <input
                    type="text"
                    value={formData.nombreContactoEmergencia || ''}
                    onChange={(e) => handleChange('nombreContactoEmergencia', e.target.value.toUpperCase())}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="MARÍA GARCÍA"
                  />
                </div>

                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Celular del Contacto <span className="text-xs text-gray-500">(9 dígitos)</span>
                  </label>
                  <input
                    type="tel"
                    maxLength={9}
                    value={formData.celularContactoEmergencia || ''}
                    onChange={(e) => handleChange('celularContactoEmergencia', e.target.value.replace(/\D/g, ''))}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="987654321"
                  />
                </div>
              </div>
            </div>
          )}

          {/* SECCIÓN 4: VEHÍCULO Y LICENCIA - Continuaré en el siguiente mensaje */}
          {seccionActual === 4 && (
            <div className="space-y-4">
              <h3 className="text-lg font-semibold text-gray-900 border-b pb-2">
                🚗 Vehículo y Licencia NEMT
              </h3>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {/* Número de Brevete */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Número de Brevete *
                  </label>
                  <input
                    type="text"
                    value={formData.numeroBrevete || ''}
                    onChange={(e) => handleChange('numeroBrevete', e.target.value.toUpperCase())}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.numeroBrevete ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    placeholder="Q12345678"
                  />
                  {errors.numeroBrevete && <p className="text-red-500 text-xs mt-1">{errors.numeroBrevete}</p>}
                </div>

                {/* Fecha Vencimiento Brevete */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Fecha Vencimiento Brevete
                  </label>
                  <input
                    type="date"
                    value={formData.fechaVencimientoBrevete || ''}
                    onChange={(e) => handleChange('fechaVencimientoBrevete', e.target.value)}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                  />
                </div>

                {/* Marca */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Marca del Vehículo *
                  </label>
                  <select
                    value={formData.marcaVehiculo || ''}
                    onChange={(e) => handleChange('marcaVehiculo', e.target.value)}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.marcaVehiculo ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                  >
                    <option value="">Seleccione marca...</option>
                    {MARCAS_VEHICULOS.map(marca => (
                      <option key={marca} value={marca}>{marca}</option>
                    ))}
                  </select>
                  {errors.marcaVehiculo && <p className="text-red-500 text-xs mt-1">{errors.marcaVehiculo}</p>}
                </div>

                {/* Modelo */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Modelo del Vehículo *
                  </label>
                  <input
                    type="text"
                    value={formData.modeloVehiculo || ''}
                    onChange={(e) => handleChange('modeloVehiculo', e.target.value)}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.modeloVehiculo ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    placeholder="Corolla, Yaris, etc."
                  />
                  {errors.modeloVehiculo && <p className="text-red-500 text-xs mt-1">{errors.modeloVehiculo}</p>}
                </div>

                {/* Placa */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Placa <span className="text-xs text-gray-500">(6-7 caracteres)</span>
                  </label>
                  <input
                    type="text"
                    maxLength={7}
                    value={formData.placa || ''}
                    onChange={(e) => handleChange('placa', e.target.value.toUpperCase())}
                    className={`w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 ${
                      errors.placa ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-blue-500'
                    }`}
                    placeholder="ABC1234"
                  />
                  {errors.placa && <p className="text-red-500 text-xs mt-1">{errors.placa}</p>}
                </div>

                {/* Año */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Año del Vehículo
                  </label>
                  <input
                    type="number"
                    min="1990"
                    max="2030"
                    value={formData.añoVehiculo || ''}
                    onChange={(e) => handleChange('añoVehiculo', parseInt(e.target.value))}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="2020"
                  />
                </div>

                {/* Tipo de Vehículo */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Tipo de Vehículo NEMT
                  </label>
                  <select
                    value={formData.tipoVehiculo || 'SEDAN'}
                    onChange={(e) => handleChange('tipoVehiculo', e.target.value)}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                  >
                    {TIPOS_VEHICULO.map(tipo => (
                      <option key={tipo.value} value={tipo.value}>{tipo.label}</option>
                    ))}
                  </select>
                </div>

                {/* Capacidad */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Capacidad de Pasajeros
                  </label>
                  <input
                    type="number"
                    min="1"
                    max="15"
                    value={formData.capacidadPasajeros || 4}
                    onChange={(e) => handleChange('capacidadPasajeros', parseInt(e.target.value))}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                  />
                </div>
              </div>
            </div>
          )}

          {/* SECCIÓN 5: ESTADO Y OBSERVACIONES */}
          {seccionActual === 5 && (
            <div className="space-y-4">
              <h3 className="text-lg font-semibold text-gray-900 border-b pb-2">
                ⚙️ Estado y Observaciones
              </h3>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {/* Estado */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Estado del Conductor
                  </label>
                  <select
                    value={formData.estado || 'ACTIVO'}
                    onChange={(e) => handleChange('estado', e.target.value)}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                  >
                    <option value="ACTIVO">Activo</option>
                    <option value="INACTIVO">Inactivo</option>
                    <option value="EN_SERVICIO">En Servicio</option>
                    <option value="EN_PERMISO">En Permiso</option>
                    <option value="SUSPENDIDO">Suspendido</option>
                    <option value="RETIRADO">Retirado</option>
                  </select>
                </div>

                {/* Fecha de Ingreso */}
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Fecha de Ingreso
                  </label>
                  <input
                    type="date"
                    value={formData.fechaIngreso || new Date().toISOString().split('T')[0]}
                    onChange={(e) => handleChange('fechaIngreso', e.target.value)}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                  />
                </div>
              </div>

              {/* Observaciones */}
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">
                  Observaciones
                </label>
                <textarea
                  rows={4}
                  value={formData.observaciones || ''}
                  onChange={(e) => handleChange('observaciones', e.target.value)}
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                  placeholder="Notas adicionales sobre el conductor..."
                />
              </div>
            </div>
          )}

          {/* FOOTER CON BOTONES */}
          <div className="flex items-center justify-between pt-6 border-t">
            <div className="flex gap-2">
              {seccionActual > 1 && (
                <button
                  type="button"
                  onClick={() => setSeccionActual(seccionActual - 1)}
                  className="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50"
                >
                  ← Anterior
                </button>
              )}
              {seccionActual < 5 && (
                <button
                  type="button"
                  onClick={() => setSeccionActual(seccionActual + 1)}
                  className="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700"
                >
                  Siguiente →
                </button>
              )}
            </div>

            <div className="flex gap-2">
              <button
                type="button"
                onClick={onClose}
                className="px-6 py-2 border border-gray-300 rounded-lg hover:bg-gray-50"
                disabled={saving}
              >
                Cancelar
              </button>
              <button
                type="submit"
                className="px-6 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg font-medium disabled:bg-gray-400"
                disabled={saving}
              >
                {saving ? 'Guardando...' : conductor ? 'Actualizar' : 'Crear Conductor'}
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  );
}